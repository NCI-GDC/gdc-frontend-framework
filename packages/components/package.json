{
  "name": "@gff/components",
  "version": "2.2.0",
  "description": "Components for GFF",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "unpkg": "dist/index.umd.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist",
    "compile": "tsc",
    "build": "rollup --config rollup.config.js",
    "build:clean": "npm run clean && npm run compile && rollup --config rollup.config.js",
    "build:watch": "npm run compile && npm run build -- --watch",
    "test": "jest unit",
    "test:watch": "jest unit --watch",
    "test:int": "jest int",
    "test:all": "jest",
    "dev": "npm run build:watch"
  },
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@mantine/core": "^5.10.2",
    "@mantine/dates": "^5.10.2",
    "@mantine/form": "^5.10.2",
    "@mantine/hooks": "^5.10.2",
    "@mantine/next": "^5.10.2",
    "@mantine/notifications": "^5.10.2",
    "file-saver": "^2.0.5"
  },
  "peerDependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.14.5",
    "@rollup/plugin-babel": "^5.3.0",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-typescript": "^8.2.1",
    "@types/jest": "^27.0.6",
    "@types/react": "^17.0.13",
    "@types/react-dom": "^17.0.8",
    "@types/file-saver": "^2.0.5",
    "@types/isomorphic-fetch": "^0.0.35",
    "@types/lodash": "^4.14.178",
    "@types/plotly.js": "^1.54.14",
    "@types/react-table": "^7.7.12",
    "jest": "^27.0.6",
    "rimraf": "^3.0.2",
    "rollup": "^2.52.7",
    "rollup-plugin-dts": "^3.0.2",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-terser": "^7.0.2",
    "ts-jest": "^27.0.3",
    "typescript": "~4.6.4"
  }
}
